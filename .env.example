# === Supabase (required — shared across all environments) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# === Upstash Redis — rate limiting (required — shared across all environments) ===
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# === LINE LIFF (required — DIFFERENT per environment) ===
# Production: prod LINE Login channel credentials
# Preview/Development: dev LINE Login channel credentials
# See Docs/environment-setup.md for the full env var matrix
NEXT_PUBLIC_LIFF_ID=your-liff-id
LINE_CHANNEL_ID=your-line-channel-id

# === LINE Messaging API — Rich Menu & Webhooks (required) ===
LINE_CHANNEL_ACCESS_TOKEN=your-messaging-api-channel-access-token
LINE_CHANNEL_SECRET=your-messaging-api-channel-secret

# === Auto-injected by Vercel (do not set manually) ===
# VERCEL_OIDC_TOKEN=

# === How to add env vars via Vercel CLI ===
# Syntax: vercel env add <NAME> <environment> [--value "xxx"]
# One environment per command — no multi-env in a single call.
# Environments: production | preview | development
#
# Example:
#   vercel env add LINE_CHANNEL_SECRET production --value "xxx"
#   vercel env add LINE_CHANNEL_SECRET preview --value "xxx"
#   vercel env add LINE_CHANNEL_SECRET development --value "xxx"
#
# Then pull all to local:
#   vercel env pull .env.local
